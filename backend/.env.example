# Required: PostgreSQL connection used by Alembic and the FastAPI app
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
SECRET_KEY=your_jwt_secret_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_EMAIL=AutoPartBazaar21@gmail.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: AWS S3 for product images.
# If left blank, uploaded images are stored locally under backend/static/product-images/.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# Optional: Zoho / SMTP for password-reset OTP emails.
# If left blank, /generateOTP and /resendOTP return 503 in local development.
EMAIL_USER=
EMAIL_PASS=
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
