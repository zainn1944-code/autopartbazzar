# Required: PostgreSQL connection used by Alembic and the FastAPI app
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
SECRET_KEY=your_jwt_secret_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_EMAIL=AutoPartBazaar21@gmail.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: AWS S3 for product images.
# If left blank, uploaded images are stored locally under backend/static/product-images/.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# Optional: Zoho / SMTP for password-reset OTP emails.
# If left blank, /generateOTP and /resendOTP return 503 in local development.
EMAIL_USER=
EMAIL_PASS=
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465

# Optional: AI recommendation endpoint via OpenRouter / Gemma.
GEMMA_API_KEY=
USD_TO_PKR_RATE=279.31

# Optional: daily live parts sync. Use comma-separated entries in NAME|URL format.
# Example:
# PARTS_FEED_URLS=TireRack|https://example.com/feed.json,eBay|https://example.com/product-page
PARTS_SYNC_ENABLED=false
PARTS_SYNC_RUN_ON_STARTUP=true
PARTS_SYNC_HOUR=1
PARTS_SYNC_MINUTE=0
PARTS_FEED_URLS=
PARTS_SYNC_TIMEOUT_SECONDS=20

# Region & category filters
PARTS_FILTER_CITY=Lahore
PARTS_FILTER_VEHICLE_TYPES=car,bike
